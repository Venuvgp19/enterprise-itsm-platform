# Database
DATABASE_URL="postgresql://itsm_user:itsm_password@localhost:5432/itsm_db?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# MinIO / S3 Storage
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET_NAME="itsm-attachments"

# JWT Authentication
JWT_SECRET="super-secret-jwt-key-change-in-production-mode-32bytes"
JWT_EXPIRATION="8h"
REFRESH_TOKEN_SECRET="refresh-secret-jwt-key-enterprise-itsm"
REFRESH_TOKEN_EXPIRATION="7d"

# App Ports
PORT=4000
FRONTEND_PORT=3000
